{{- $theme := includeTemplate "palettes/active-theme" . | fromJson -}}
export FZF_DEFAULT_OPTS='--height 40% --tmux bottom,40% --layout reverse --border top'
{{ if eq $theme.name "tokyonight" }}
export FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS \
  --color=bg:{{ $theme.ui.bg_dark }},bg+:{{ $theme.ui.selection }},fg:{{ $theme.ui.fg }} \
  --color=border:{{ $theme.ui.border_highlight }},gutter:{{ $theme.ui.bg_dark }} \
  --color=header:{{ $theme.accent.orange }},hl:{{ $theme.accent.blue1 }},hl+:{{ $theme.accent.blue1 }} \
  --color=info:{{ $theme.accent.dark3 }},pointer:{{ $theme.accent.magenta2 }},marker:{{ $theme.accent.magenta2 }} \
  --color=prompt:{{ $theme.accent.blue1 }},query:{{ $theme.ui.fg }}:regular \
  --color=scrollbar:{{ $theme.ui.border_highlight }},separator:{{ $theme.accent.orange }},spinner:{{ $theme.accent.magenta2 }}"
{{ else if eq $theme.name "catppuccin" }}
export FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS \
  --color=bg+:{{ $theme.ui.bg_highlight }},bg:{{ $theme.ui.bg }},spinner:{{ $theme.accent.rosewater }},hl:{{ $theme.accent.red }} \
  --color=fg:{{ $theme.ui.fg }},header:{{ $theme.accent.red }},info:{{ $theme.accent.mauve }},pointer:{{ $theme.accent.rosewater }} \
  --color=marker:{{ $theme.accent.rosewater }},fg+:{{ $theme.ui.fg }},prompt:{{ $theme.accent.mauve }},hl+:{{ $theme.accent.red }}"
{{ end }}

# Build FZF exclude options from config file
FZF_FD_OPTIONS="--follow"
if [[ -f ${XDG_CONFIG_HOME:-$HOME/.config}/fzf/excludes ]]; then
  while IFS= read -r pattern; do
    [[ -z "$pattern" || "$pattern" =~ ^# ]] && continue  # skip empty lines and comments
    FZF_FD_OPTIONS="$FZF_FD_OPTIONS --exclude $pattern"
  done < "${XDG_CONFIG_HOME:-$HOME/.config}/fzf/excludes"
fi
export FZF_FD_OPTIONS
export FZF_DEFAULT_COMMAND="fd --type f --type l --hidden $FZF_FD_OPTIONS"
export FZF_CTRL_T_COMMAND="fd $FZF_FD_OPTIONS"
export FZF_ALT_C_COMMAND="fd --type d --hidden $FZF_FD_OPTIONS"
export FZF_CTRL_T_OPTS="
  --preview '[ -d {} ] && eza -T {} || bat -n --color=always {}'
  --bind 'ctrl-/:change-preview-window(down|hidden|)'"
export FZF_ALT_C_OPTS="
  --preview 'eza -T {}'"

if [[ -f ${ZDOTDIR:-$HOME}/fzf-git.sh ]]; then
  # unbind CTRL-G first.
  # If not fzf-git keybind are not working because it is bound to list-expand by default
  bindkey -r '^G'
  source ${ZDOTDIR:-$HOME}/fzf-git.sh
fi
