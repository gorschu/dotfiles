{{- $configHome := env "XDG_CONFIG_HOME" | default (joinPath .chezmoi.homeDir ".config") }}
# Include dropin configuration files from topgrade.d/
[include]
paths = [
  "{{ joinPath $configHome "topgrade/topgrade.d/post_commands-ansible.toml" }}",
  "{{ joinPath $configHome "topgrade/topgrade.d/post_commands-homebrew-systemd.toml" }}",
]

[misc]
disable = ["jetbrains_toolbox"]
