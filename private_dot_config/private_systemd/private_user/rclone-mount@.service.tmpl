[Unit]
Description=rclone FUSE mount for %i
Documentation=https://rclone.org/commands/rclone_mount/
After=network.target
ConditionPathExists=%h/.config/rclone/rclone.conf

[Service]
Type=notify
ExecStartPre=/usr/bin/mkdir -p %h/Cloud/%i
ExecStart={{ lookPath "rclone" | default (printf "%s/bin/rclone" .homebrew.prefix) }} mount %i: %h/Cloud/%i \
    --vfs-cache-mode writes \
    --vfs-cache-max-size 1G \
    --dir-cache-time 5m \
    --poll-interval 1m
ExecStop=/usr/bin/fusermount3 -uz %h/Cloud/%i
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
