{{- $theme := includeTemplate "palettes/active-theme" . | fromJson -}}
{{- $personalColor := $theme.semantic.primary -}}
{{- $workColor := $theme.semantic.success -}}
{{- $tasksColor := $theme.semantic.warning -}}
# khal configuration - managed by chezmoi

[calendars]

[[calendars.Personal]]
path = ~/.local/share/vdirsyncer/calendars/Personal
color = {{ $personalColor }}

[[calendars.Work]]
path = ~/.local/share/vdirsyncer/calendars/Work
color = {{ $workColor }}

[[calendars.Tasks]]
path = ~/.local/share/vdirsyncer/calendars/Tasks
color = {{ $tasksColor }}

[sqlite]
path = ~/.local/share/khal/khal.db

[locale]
timeformat = %H:%M
dateformat = %Y-%m-%d
datetimeformat = %Y-%m-%d %H:%M
