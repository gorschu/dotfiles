# HTML - view in browser or use w3m for inline
text/html; xdg-open %s ; nametemplate=%s.html ; needstrict
text/html; w3m -I %{charset} -T text/html; copiousoutput

# Images
image/*; xdg-open %s ; needstrict

# PDF - auto-view as text
application/pdf; pdftotext -layout %s -; copiousoutput
application/pdf; xdg-open %s

# Office documents
application/vnd.openxmlformats-officedocument.wordprocessingml.document; pandoc -f docx -t plain %s; copiousoutput
application/vnd.oasis.opendocument.text; pandoc -f odt -t plain %s; copiousoutput
application/msword; pandoc -f doc -t plain %s; copiousoutput

# Fallback to xdg-open
*/*; xdg-open %s ; needstrict
