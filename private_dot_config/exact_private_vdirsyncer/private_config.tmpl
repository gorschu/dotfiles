{{- $secrets := includeTemplate "secrets/secrets-mail" . | fromJson -}}
# vdirsyncer configuration - managed by chezmoi

[general]
status_path = "~/.local/share/vdirsyncer/status/"

[pair tasks_fastmail]
a = "tasks_local"
b = "tasks_remote"
collections = null
conflict_resolution = "b wins"

[storage tasks_local]
type = "filesystem"
path = "~/.local/share/vdirsyncer/tasks/"
fileext = ".ics"

[storage tasks_remote]
type = "caldav"
url = "{{ $secrets.fastmail.dav_tasks_url }}"
username = "{{ $secrets.fastmail.email }}"
password = "{{ $secrets.fastmail.dav_tasks_password }}"
item_types = ["VTODO"]
