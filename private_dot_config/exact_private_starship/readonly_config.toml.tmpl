vimcmd_symbol = "[<<=](bold yellow) "
vimcmd_visual_symbol = "[<<=](bold cyan) "

[cmd_duration]
disabled = false
format = "ΌβΒ  [$duration]($style) "
min_time_to_notify = 180000
show_notifications = true

[conda]
