#!/usr/bin/env bash
# Bootstrap Nix + home-manager. Idempotent via command -v guards.
# run_onchange means this reruns whenever its own content changes (e.g. installer
# flag tweaks), but skips silently when both tools are already present.

set -euo pipefail

# 1. Determinate Nix
if ! command -v nix >/dev/null 2>&1; then
  echo "Installing Determinate Nix..."
  curl -fsSL https://install.determinate.systems/nix | sh -s -- install --determinate --no-confirm
fi

# Determinate manages /etc/nix/nix.conf and overwrites it on upgrades.
# Custom settings belong in /etc/nix/nix.custom.conf, which the managed file
# !includes. We seed:
#   - trusted-users: lets @wheel members add substituters at flake level
#   - extra-substituters / extra-trusted-public-keys: the Numtide cache used
#     for llm-agents.nix builds, set globally so flake nixConfig is unneeded
#     (avoids the per-user accept-flake-config prompt on fresh hosts).
#
# Each line is checked exactly so adding one doesn't depend on whether
# another is already present.

ensure_line() {
  local line="$1"
  if ! sudo grep -qFx "$line" /etc/nix/nix.custom.conf 2>/dev/null; then
    echo "  + $line"
    echo "$line" | sudo tee -a /etc/nix/nix.custom.conf >/dev/null
    return 0
  fi
  return 1
}

needs_restart=0
echo "Reconciling /etc/nix/nix.custom.conf..."
ensure_line 'trusted-users = root @wheel' && needs_restart=1
ensure_line 'extra-substituters = https://cache.numtide.com' && needs_restart=1
ensure_line 'extra-trusted-public-keys = niks3.numtide.com-1:DTx8wZduET09hRmMtKdQDxNNthLQETkc/yaX7M4qK0g=' && needs_restart=1

if [[ $needs_restart -eq 1 ]]; then
  sudo systemctl restart nix-daemon
fi

# 2. home-manager (requires nix from step 1; source the daemon env in case nix
# was just installed in this same apply run and isn't on PATH yet).
if [[ -f /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh ]]; then
  . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
fi

if command -v nix >/dev/null 2>&1 && ! command -v home-manager >/dev/null 2>&1; then
  echo "Installing home-manager..."
  nix profile add nixpkgs#home-manager
fi
